APP_NAME=Shortdrama Agent
APP_VERSION=0.1.0
DEBUG=false

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=shortdrama
POSTGRES_USER=shortdrama_test
POSTGRES_PASSWORD=change-me
POSTGRES_SCHEMA=common

# 火山方舟大模型，用于 Excel 字段理解抽取
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=change-me
ARK_LLM_MODEL=your-ark-endpoint-id
DOUBAO_LLM_MODEL=
DOUBAO_EMBEDDING_MODEL=your-doubao-embedding-endpoint-id

# 火山 TOS，用于上传 Excel 内嵌图片
TOS_BUCKET=drama-asset
TOS_SDK_ENDPOINT=https://tos-cn-beijing.volces.com
TOS_PUBLIC_BASE_URL=https://drama-asset.tos-cn-beijing.volces.com
TOS_REGION=cn-beijing
TOS_ACCESS_KEY=change-me
TOS_SECRET_KEY=change-me

# Milvus 向量库
MILVUS_URI=http://localhost:19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_COLLECTION_ASSET_ENTITY=asset_entity_vectors
MILVUS_COLLECTION_PROJECT_STORYBOARD=project_storyboard_vectors
